PORT=3005
NODE_ENV=development

# IP Tailscale de la machine hôte (optionnel — accès réseau distant)
TAILSCALE_IP=XXX.XXX.XX.XXX

# Cache (en millisecondes)
CACHE_TTL_PREVISIONS=600000      # 10 minutes
CACHE_TTL_GEOCODE=2592000000     # 30 jours

# Timezone par défaut pour les prévisions Open-Meteo
DEFAULT_TIMEZONE=America/Toronto
