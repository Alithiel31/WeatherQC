{
  "name": "meteo-qc-backend",
  "version": "2.0.0",
  "description": "API meteo pour le Canada (proxy Open-Meteo avec cache)",
  "type": "module",
  "main": "app.ts",
  "scripts": {
    "dev": "tsx --watch app.ts",
    "start": "tsx app.ts",
    "build": "tsc",
    "prod": "node dist/app.js",
    "lint": "eslint src/ app.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format && npm run build && npm run lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.svelte": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^2.0.12",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.3.0",
    "supertest": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
